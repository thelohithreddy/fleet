# MongoDB Atlas
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT (required for login/signup)
JWT_SECRET=your-long-random-secret

# CORS — comma-separated Vercel URLs (no trailing slash)
# Example: https://fleet.vercel.app,https://fleet-git-main-user.vercel.app
FRONTEND_URL=https://your-frontend.vercel.app

# Gmail OTP (use a Google App Password, not your normal password)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-char-app-password

# Support contact shown in Help / API
SUPPORT_EMAIL=gaddampallylohithreddy7@gmail.com
OTP_RESEND_COOLDOWN_SEC=60

# Legacy aliases (still supported if EMAIL_* are not set)
# gmail=your-email@gmail.com
# app_pass=your-16-char-app-password

# Render sets this automatically
PORT=5000
NODE_ENV=production
